{
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "edit_predictions": {
    "provider": "copilot",
    "disabled_globs": ["*.env*"],
  },
  "icon_theme": "Colored Zed Icons Theme Dark",
  "agent": {
    "dock": "right",
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.1",
      "enable_thinking": false
    },
    "tool_permissions": {
      "default": "allow",
    },
    "default_profile": "write",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.1-codex-max",
    },
  },
  "vim_mode": false,
  "base_keymap": "VSCode",
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Tokyo Night",
    "dark": "Noctalia Dark",
  },
  "lsp": {
    "rust-analyzer": {
      "binary": {
        "path": "/usr/bin/rust-analyzer",
      },
    },
  },
  "language_models": {
    "openai_compatible": {
      "api_url": {
        "api_url": "http://localhost:1234/v1",
        "available_models": [
          {
            "name": "DeepSeekCoderLocal",
            "display_name": "DeepSeek Coder V2 Lite (local)",
            "max_tokens": 16384,
          },
        ],
      },
    },
  },
}
